# URL pública del sitio (sin barra final). SEO: canonical, Open Graph, JSON-LD.
# VITE_SITE_URL=https://estudiopopnest.com

# Número de WhatsApp (solo dígitos, con código de país, sin +)
# Ejemplo: México 55 5437 9644 → 525554379644
VITE_WHATSAPP_PHONE=525554379644

# URL completa de la plataforma Wellness (menú); por defecto https://popnest.app/
# VITE_WELLNESS_URL=https://popnest.app/

# Instagram (footer); por defecto https://www.instagram.com/estudio_popnest/
# VITE_INSTAGRAM_URL=https://www.instagram.com/estudio_popnest/

# Enlace fijo del lugar en Google Maps (opcional; por defecto maps.app.goo.gl del negocio)
# VITE_GOOGLE_MAPS_URL=https://maps.app.goo.gl/...
